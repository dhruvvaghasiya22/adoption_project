# Flask configurations
SECRET_KEY=super-secret-pet-adoption-key-12345
DATABASE_URL=sqlite:///database.db

# Email/SMTP settings (smtplib with SMTP_SSL)
# Replace these with your actual SMTP server credentials (e.g. Gmail App Password)
MAIL_SERVER=smtp.gmail.com
MAIL_PORT=465
MAIL_USERNAME=your-email@gmail.com
MAIL_PASSWORD=your-app-password
ADMIN_EMAIL=admin@petadopt.com

# Email Provider Selection ('smtp' or 'sendgrid')
EMAIL_PROVIDER=smtp

# SendGrid configurations (if EMAIL_PROVIDER=sendgrid)
SENDGRID_API_KEY=SG.your_sendgrid_api_key_here

# GetStream configurations
STREAM_API_KEY=your_stream_api_key_here
STREAM_API_SECRET=your_stream_api_secret_here
STREAM_APP_ID=your_stream_app_id_here
